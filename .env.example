# Application Configuration
NODE_ENV=development
APP_URL=http://localhost:3000
APP_HOST=localhost
APP_PORT=3000
FRONTEND_URL=http://localhost:5173

# Sentry Error Tracking (Optional)
# Get your DSN from https://sentry.io/settings/
SENTRY_URL=

# Better-Auth Configuration (Required)
# Secret for signing session tokens - min 32 characters
BETTER_AUTH_SECRET=your-better-auth-secret-min-32-characters-long
# Base URL for the API (used for auth redirects and links)
API_BASE_URL=http://localhost:3000
# Comma-separated list of trusted origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database Configuration (Required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=illustrious
DB_USERNAME=admin
DB_PASSWORD=illustrious
DB_SSL=false

# reCAPTCHA Configuration (Optional)
# Leave empty to skip verification in development
RECAPTCHA_SECRET_KEY=
RECAPTCHA_SCORE_THRESHOLD=0.5

# Email Configuration (Optional - Nodemailer)
# Use your email address for MAIL_USER and MAIL_FROM
# For MAIL_PASS, use an app password if required by your provider
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

# OAuth Configuration (Optional)
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
