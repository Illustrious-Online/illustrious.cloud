{
  "name": "illustrious.cloud",
  "version": "1.1.0",
  "private": true,
  "resolve": {
    "fallback": {
      "crypto": false
    }
  },
  "release": {
    "branches": [
      "main",
      "next"
    ]
  },
  "scripts": {
    "dev": "bun run --watch ./src/app.ts",
    "build": "bun build ./src/app.ts --target node --outdir ./dist",
    "start": "concurrently \"bun run dev\" \"bun run db:start\"",
    "db:start": "docker compose -f docker-compose.db.yml up -d && bun run db:migrate",
    "db:stop": "docker stop illustriouscloud-postgres-1",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:reset": "./src/utils/reset-db.sh",
    "check": "bunx @biomejs/biome check ./src",
    "check:fix": "bunx @biomejs/biome check --write ./src",
    "test:local": "bun run db:start && bun test",
    "test:local:coverage": "bun run db:start && bun test --coverage"
  },
  "dependencies": {
    "@biomejs/biome": "^1.9.4",
    "@elysiajs/cors": "^1.0.2",
    "@elysiajs/eden": "latest",
    "@elysiajs/swagger": "^1.0.5",
    "@sentry/bun": "^10.32.1",
    "@tqman/nice-logger": "^1.1.1",
    "axios": "^1.6.8",
    "better-auth": "latest",
    "concurrently": "^9.1.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "http-status-codes": "^2.3.0",
    "moment": "^2.30.1",
    "nodemailer": "^7.0.11",
    "pg": "^8.11.5",
    "postgres": "^3.4.4",
    "semantic-release": "^25.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@types/bun": "^1.2.2",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.6",
    "@types/uuid": "^10.0.0",
    "bun-types": "latest",
    "codecov": "^3.8.3",
    "drizzle-kit": "^0.30.2",
    "jsdom": "^26.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.9.3",
    "vitest": "^3.0.4",
    "yoctocolors": "^2.1.1"
  },
  "module": "src/app.ts",
  "trustedDependencies": [
    "core-js",
    "core-js-pure",
    "es5-ext",
    "esbuild",
    "sharp"
  ]
}
