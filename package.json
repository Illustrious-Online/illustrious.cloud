{
  "name": "illustrious.cloud",
  "version": "1.3.0",
  "private": true,
  "resolve": {
    "fallback": {
      "crypto": false
    }
  },
  "release": {
    "branches": [
      "main",
      "next"
    ]
  },
  "scripts": {
    "dev": "bun run --watch ./src/app.ts",
    "build": "bun build ./src/app.ts --target node --outdir ./dist",
    "start": "concurrently \"bun run dev\" \"bun run db:start\"",
    "db:start": "docker compose -f docker-compose.db.yml up -d && bun run db:migrate",
    "db:stop": "docker stop illustriouscloud-postgres-1",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:reset": "./src/utils/reset-db.sh",
    "check": "bunx @biomejs/biome check .",
    "check:fix": "bunx @biomejs/biome check --write .",
    "check:fix:unsafe": "bunx @biomejs/biome check --write --unsafe .",
    "test:local": "bun run db:start && bun test",
    "test:local:coverage": "mkdir -p reports && bun run db:start && bun test --coverage"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.4",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "latest",
    "@elysiajs/swagger": "^1.3.1",
    "@sentry/bun": "^10.39.0",
    "@tqman/nice-logger": "^1.1.1",
    "axios": "^1.13.5",
    "better-auth": "latest",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "latest",
    "http-status-codes": "^2.3.0",
    "moment": "^2.30.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "semantic-release": "^25.0.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "^1.3.9",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^11.0.0",
    "bun-types": "latest",
    "codecov": "^3.8.3",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^28.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "vitest": "^4.0.18",
    "yoctocolors": "^2.1.2"
  },
  "module": "src/app.ts",
  "trustedDependencies": [
    "core-js",
    "core-js-pure",
    "es5-ext",
    "esbuild",
    "sharp"
  ]
}
