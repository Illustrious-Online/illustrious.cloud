{
  "name": "illustrious.cloud",
  "version": "1.1.0",
  "private": true,
  "resolve": {
    "fallback": {
      "crypto": false
    }
  },
  "release": {
    "branches": [
      "main",
      "next"
    ]
  },
  "scripts": {
    "dev": "bun run --watch ./src/app.ts",
    "build": "bun build ./src/app.ts --target node --outdir ./dist",
    "start": "concurrently \"bun run dev\" \"bun run db:start\"",
    "db:start": "docker compose -f docker-compose.db.yml up -d && bun run db:migrate",
    "db:stop": "docker stop illustriouscloud-postgres-1",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:reset": "./src/utils/reset-db.sh",
    "check": "bunx @biomejs/biome check ./src",
    "check:fix": "bunx @biomejs/biome check --write ./src",
    "prepare": "bunx husky",
    "test:local": "bun run db:stop && bun run db:start && bun test",
    "demo:eden": "bun run src/demo/eden-treaty-demo.ts"
  },
  "dependencies": {
    "@biomejs/biome": "^2.2.6",
    "@elysiajs/bearer": "^1.4.1",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/eden": "^1.4.4",
    "@elysiajs/swagger": "^1.3.1",
    "@sentry/bun": "^10.19.0",
    "@supabase/supabase-js": "^2.75.0",
    "@tqman/nice-logger": "^1.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-steam-openid": "^1.0.3",
    "@types/nodemailer": "^7.0.2",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.6",
    "elysia": "latest",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "moment": "^2.30.1",
    "node-steam-openid": "^2.0.0",
    "nodemailer": "^7.0.9",
    "openid-client": "^6.8.1",
    "pg": "^8.16.3",
    "semantic-release": "^24.2.9",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.1.0",
    "@types/bun": "^1.3.0",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^11.0.0",
    "axios": "^1.12.2",
    "bun-types": "latest",
    "codecov": "^3.8.3",
    "drizzle-kit": "^0.31.5",
    "jsdom": "^27.0.0",
    "postgres": "^3.4.7",
    "supabase": "^2.51.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "uuid": "^13.0.0",
    "vitest": "^3.2.4",
    "yoctocolors": "^2.1.2"
  },
  "module": "src/app.ts",
  "trustedDependencies": [
    "core-js",
    "core-js-pure",
    "es5-ext",
    "esbuild",
    "sharp"
  ]
}
