# =============================================================================
# ILLUSTRIOUS CLOUD - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and update the values according to your environment
# =============================================================================

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
NODE_ENV=development
APP_URL=http://localhost:3000
APP_HOST=localhost
APP_PORT=3000

# Sentry Configuration (Optional)
SENTRY_URL=

# =============================================================================
# AUTHENTICATION & SUPABASE
# =============================================================================
SUPABASE_ID=your_supabase_project_id
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_EDGE_KEY=your_supabase_edge_key

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=illustrious
DB_USERNAME=admin
DB_PASSWORD=illustrious
DB_SSL=false

# =============================================================================
# EMAIL SERVICE CONFIGURATION
# =============================================================================
# Email settings for sending inquiry notifications
# Configure these for GoDaddy Outlook or your preferred SMTP provider
EMAIL_USER=info@illustrious.cloud
EMAIL_PASSWORD=your_godaddy_email_password
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587

# =============================================================================
# RECAPTCHA CONFIGURATION
# =============================================================================
# reCAPTCHA settings for inquiry form protection
# Get these from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================
# 
# 1. DATABASE SETUP:
#    - For local development, use the provided docker-compose.db.yml
#    - Run: docker compose -f docker-compose.db.yml up -d
#    - Then run: bun run db:migrate
#
# 2. EMAIL SETUP:
#    - For GoDaddy Outlook, use the provided EMAIL_* variables
#    - For other providers, update EMAIL_HOST and EMAIL_PORT accordingly
#    - Test email functionality with the inquiry endpoint
#
# 3. RECAPTCHA SETUP:
#    - Visit https://www.google.com/recaptcha/admin
#    - Create a new site with reCAPTCHA v2
#    - Add your domains (localhost for development)
#    - Copy the Site Key and Secret Key to the variables above
#
# 4. PRODUCTION DEPLOYMENT:
#    - Set NODE_ENV=production
#    - Configure all required environment variables
#    - Ensure database is properly configured
#    - Set up proper SSL certificates for production
#
# =============================================================================
